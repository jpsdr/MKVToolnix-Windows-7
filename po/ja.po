msgstr "自動で判定"

#: src/mkvtoolnix-gui/merge/input.cpp:1829
#, no-c-format
msgid "No extra compression"
msgstr "追加圧縮なし"

#: src/mkvtoolnix-gui/merge/input.cpp:1830
#, no-c-format
msgid "Only for I frames"
msgstr "I フレームのみ"

#: src/mkvtoolnix-gui/merge/input.cpp:1830
#, no-c-format
msgid "For all frames"
msgstr "すべてのフレーム"

#: src/mkvtoolnix-gui/merge/input.cpp:1830
#, no-c-format
msgid "No cues"
msgstr "キュー無し"

