#, no-c-format
msgid "Append media files"
msgstr "メディアファイルを追加結合する"

#: src/mkvtoolnix-gui/merge/input.cpp:1559
#, no-c-format
msgid "Add media files"
msgstr "メディアファイルを追加"

#: src/mkvtoolnix-gui/merge/input.cpp:1671
