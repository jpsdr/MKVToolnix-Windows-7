msgstr "トラックを含まないファイルをファイルに追加することはできません。"

#: src/mkvtoolnix-gui/merge/input.cpp:1675
#, no-c-format
msgid "Add media files as additional parts"
msgstr "追加部分としてメディアファイルを追加"

