#: src/mkvtoolnix-gui/merge/tab.cpp:425
#: src/mkvtoolnix-gui/merge/tab.cpp:437
#, no-c-format
msgid "Cannot start multiplexing"
msgstr "マルチプレクシングを開始できません"

#: src/mkvtoolnix-gui/merge/tab.cpp:425
#, no-c-format
msgid "You have to set the destination file name before you can start multiplexing or add a job to the job queue."
msgstr "ジョブを追加したりマルチプレクシングを開始する前に、出力ファイル名を設定する必要があります。"

#: src/mkvtoolnix-gui/merge/tab.cpp:437
#, no-c-format
msgid "The destination file name is invalid and must be fixed before you can start multiplexing or add a job to the job queue."
msgstr "出力ファイル名が無効です。ジョブを追加したりマルチプレクシングを開始する前に修正してください。"

#: src/mkvtoolnix-gui/merge/tab.cpp:511
#, no-c-format
msgid "Create file without audio track"
msgstr "音声トラックなしでファイルを作成"

#: src/mkvtoolnix-gui/merge/tab.cpp:513
#, no-c-format
msgid "With the current multiplex settings the destination file will not contain an audio track."
msgstr "現在のマルチプレクシング設定では、出力ファイルに音声トラックは含まれません。"

#: src/mkvtoolnix-gui/merge/tab.cpp:514
#, no-c-format
msgid "Do you want to continue?"
msgstr "続行しますか？"

#: src/mkvtoolnix-gui/merge/tab.cpp:515
#, no-c-format
msgid "&Create file without audio track"
msgstr "音声トラックなしでファイルを作成(&C)"

#: src/mkvtoolnix-gui/merge/tab.cpp:591
#, no-c-format
