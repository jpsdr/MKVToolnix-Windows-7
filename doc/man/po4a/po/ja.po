#: doc/man/mkvtoolnix-gui.xml:137
msgid "&mkvmerge;, &mkvextract;, &mkvinfo;, &mkvpropedit;"
msgstr "&mkvmerge;、&mkvextract;、&mkvinfo;、&mkvpropedit;"

